# Caddyfile for manager.hazlosoftware.com

manager.hazlosoftware.com {
  # Serve built frontend (adjust path to where you place the build on the server)
  root * /var/www/manager/frontend/dist
  encode zstd gzip

  # Security headers
  header {
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer-when-downgrade"
    X-XSS-Protection "1; mode=block"
  }

  # Proxy API requests to backend Node.js
  handle_path /api/* {
    reverse_proxy localhost:3000 {
      header_up Host {http.request.host}
      header_up X-Real-IP {http.request.remote}
      header_up X-Forwarded-For {http.request.remote}
      header_up X-Forwarded-Proto {http.request.scheme}
    }
  }

  # SPA fallback: serve index.html for other routes
  try_files {path} /index.html
  file_server
}
